{
  "id": "timestamp-tools",
  "name": "timestamp-tools",
  "version": "1.0.0",
  "displayName": "Timestamp Tools",
  "description": "Copy current ISO or Unix timestamps for quick utility workflows.",
  "main": "main.js",
  "features": [
    {
      "code": "iso-now",
      "explain": "Copy the current ISO timestamp",
      "cmds": [
        {
          "type": "keyword",
          "value": "ts iso"
        }
      ]
    },
    {
      "code": "unix-now",
      "explain": "Copy the current Unix timestamp",
      "cmds": [
        {
          "type": "keyword",
          "value": "ts unix"
        }
      ]
    }
  ]
}
