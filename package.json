{
  "name": "mulby",
  "version": "0.2.0",
  "description": "跨平台插件式效率工具箱",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:smoke": "npm run build",
    "install:cli-deps": "npm ci --prefix packages/mulby-cli --no-audit --no-fund",
    "electron:dev": "vite",
    "electron:build": "vite build && electron-builder",
    "electron:publish": "vite build && electron-builder --publish always",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "check:api-docs": "node scripts/check-api-docs.mjs",
    "test:unit": "node scripts/run-unit-tests.mjs",
    "verify:app": "npm run typecheck && npm run lint && npm run check:api-docs && npm run test:unit && npm run build:smoke",
    "verify:cli": "npm run verify --prefix packages/mulby-cli",
    "verify:repo": "npm run verify:app && npm run verify:cli",
    "verify": "npm run verify:app"
  },
  "author": "Unicellular-SU <UnicellularSU@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^9.39.2",
    "node-gyp": "^12.2.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.52.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.15.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.35",
    "@ai-sdk/google": "^3.0.20",
    "@ai-sdk/openai": "^3.0.25",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/sharp": "^0.31.1",
    "ai": "^6.0.67",
    "better-sqlite3": "^9.2.2",
    "cron-parser": "^5.5.0",
    "electron-get-location": "^1.0.1",
    "electron-log": "^5.0.0",
    "electron-updater": "^6.8.3",
    "extract-zip": "^2.0.1",
    "js-tiktoken": "^1.0.21",
    "lucide-react": "^0.562.0",
    "node-addon-api": "^8.5.0",
    "pinyin-pro": "^3.28.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "uiohook-napi": "^1.5.5",
    "yaml": "^2.8.1",
    "zustand": "^4.4.7"
  },
  "optionalDependencies": {
    "node-mac-permissions": "^2.5.0"
  },
  "build": {
    "appId": "com.mulby.app",
    "productName": "Mulby",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "publish": {
      "provider": "github",
      "owner": "Unicellular-SU",
      "repo": "mulby-releases",
      "releaseType": "release"
    },
    "mac": {
      "icon": "icon.icns",
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "extendInfo": {
        "NSLocationWhenInUseUsageDescription": "Mulby 需要访问您的位置以提供位置相关功能（如地图定位、天气查询等）",
        "NSLocationUsageDescription": "Mulby 需要访问您的位置以提供位置相关功能",
        "NSCameraUsageDescription": "插件可能需要访问摄像头以提供拍照、视频等功能",
        "NSMicrophoneUsageDescription": "插件可能需要访问麦克风以提供录音、语音识别等功能"
      }
    },
    "asarUnpack": [
      "node_modules/electron-get-location/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/node-mac-permissions/**/*",
      "node_modules/sharp/**/*",
      "node_modules/@img/sharp-*/**/*",
      "node_modules/@img/sharp-libvips-*/**/*",
      "node_modules/uiohook-napi/**/*"
    ],
    "afterPack": "scripts/electron-builder-after-pack.cjs",
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin"
      },
      {
        "from": "resources/tray",
        "to": "resources/tray"
      }
    ],
    "win": {
      "icon": "icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    },
    "linux": {
      "icon": "build/icons/linux",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}