{
  "name": "mulby",
  "version": "0.9.7",
  "description": "跨平台插件式效率工具箱",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:bundle": "vite build",
    "electron:build": "pnpm run native:build && vite build && electron-builder",
    "electron:build:mac:unsigned": "pnpm run native:build && MULBY_MAC_UNSIGNED_RESOURCE_UPDATES=true vite build && electron-builder --mac --publish never",
    "electron:build:mac:unsigned:prepared": "MULBY_MAC_UNSIGNED_RESOURCE_UPDATES=true vite build && electron-builder --mac --publish never",
    "electron:publish": "pnpm run native:build && vite build && electron-builder --publish always",
    "electron:publish:prepared": "vite build && electron-builder --publish always",
    "mac:resource-update": "node scripts/generate-mac-resource-update.cjs",
    "mac:verify-signing": "node scripts/verify-mac-app-signing.cjs",
    "postinstall": "node scripts/postinstall.mjs",
    "native:build": "node scripts/build-native.mjs",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "check:api-docs": "node scripts/check-api-docs.mjs",
    "check:models-dev": "node scripts/check-modelsdev.mjs",
    "reset:onboarding": "node scripts/reset-onboarding.mjs",
    "sync:api-docs": "node scripts/sync-skill-docs.mjs",
    "sync:models-dev": "node scripts/sync-modelsdev.mjs",
    "sync:skills": "pnpm run sync:api-docs && bash scripts/link-skills.sh",
    "test:unit": "node scripts/run-unit-tests.mjs",
    "test:mcp-verify": "node scripts/test-mcp-verify.mjs",
    "verify:plugin": "node scripts/verify-plugin.mjs",
    "verify:app": "pnpm run typecheck && pnpm run lint && pnpm run check:api-docs && pnpm run sync:api-docs && pnpm run test:unit && pnpm run build:bundle"
  },
  "author": "Unicellular-SU <UnicellularSU@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@electron/asar": "^3.4.1",
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.2",
    "node-gyp": "^12.2.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.52.0",
    "vite": "^8.0.3",
    "vite-plugin-electron": "^0.29.1",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.35",
    "@ai-sdk/google": "^3.0.20",
    "@ai-sdk/openai": "^3.0.25",
    "@ai-sdk/provider": "3.0.8",
    "@ai-sdk/provider-utils": "4.0.23",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@mozilla/readability": "^0.6.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/sharp": "^0.31.1",
    "ai": "^6.0.67",
    "better-sqlite3": "^12.8.0",
    "cron-parser": "^5.5.0",
    "dbus-next": "^0.10.2",
    "electron-get-location": "^1.0.1",
    "electron-log": "^5.0.0",
    "electron-updater": "^6.8.3",
    "extract-zip": "^2.0.1",
    "js-tiktoken": "^1.0.21",
    "koffi": "^2.15.2",
    "lucide-react": "^1.7.0",
    "node-addon-api": "^8.5.0",
    "pinyin-pro": "^3.28.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "tree-kill": "^1.2.2",
    "turndown": "^7.2.4",
    "ws": "^8.20.0",
    "yaml": "^2.8.1",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "node-mac-permissions": "^2.5.0"
  },
  "build": {
    "appId": "com.mulby.app",
    "productName": "Mulby",
    "protocols": {
      "name": "Mulby",
      "schemes": [
        "mulby"
      ]
    },
    "files": [
      "dist/**/*",
      "native/build/Release/*.node",
      "package.json"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "publish": {
      "provider": "github",
      "owner": "Unicellular-SU",
      "repo": "mulby-releases",
      "releaseType": "release"
    },
    "mac": {
      "identity": null,
      "icon": "icon.icns",
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "extendInfo": {
        "NSLocationWhenInUseUsageDescription": "Mulby 需要访问您的位置以提供位置相关功能（如地图定位、天气查询等）",
        "NSLocationUsageDescription": "Mulby 需要访问您的位置以提供位置相关功能",
        "NSCameraUsageDescription": "插件可能需要访问摄像头以提供拍照、视频等功能",
        "NSMicrophoneUsageDescription": "插件可能需要访问麦克风以提供录音、语音识别等功能",
        "CFBundleURLTypes": [
          {
            "CFBundleURLName": "com.mulby.app",
            "CFBundleURLSchemes": [
              "mulby"
            ]
          }
        ]
      }
    },
    "asarUnpack": [
      "node_modules/electron-get-location/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/node-mac-permissions/**/*",
      "node_modules/sharp/**/*",
      "node_modules/@img/sharp-*/**/*",
      "node_modules/@img/sharp-libvips-*/**/*",
      "node_modules/koffi/**/*",
      "native/build/Release/*.node"
    ],
    "beforeBuild": "scripts/electron-builder-before-build.cjs",
    "afterPack": "scripts/electron-builder-after-pack.cjs",
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin"
      },
      {
        "from": "resources/updater",
        "to": "updater",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/tray",
        "to": "resources/tray"
      },
      {
        "from": "src/main/ai/mcp-server/stdio-bridge.cjs",
        "to": "mcp/stdio-bridge.cjs"
      },
      {
        "from": "native/win32-text-selection/build/Release/text_selection.dll",
        "to": "native/win32-text-selection/text_selection.dll",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "native/build/Release",
        "to": "native/build/Release",
        "filter": [
          "*.node"
        ]
      },
      {
        "from": "internal-plugins",
        "to": "internal-plugins",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    },
    "linux": {
      "icon": "build/icons/linux",
      "target": [
        "AppImage",
        "deb"
      ],
      "mimeTypes": [
        "x-scheme-handler/mulby"
      ]
    }
  }
}