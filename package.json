{
  "name": "intools",
  "version": "0.1.0",
  "description": "跨平台插件式效率工具箱",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^9.39.2",
    "node-gyp": "^12.2.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.52.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.15.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.35",
    "@ai-sdk/google": "^3.0.20",
    "@ai-sdk/openai": "^3.0.25",
    "@tailwindcss/typography": "^0.5.19",
    "@types/sharp": "^0.31.1",
    "ai": "^6.0.67",
    "better-sqlite3": "^9.2.2",
    "cron-parser": "^5.5.0",
    "electron-get-location": "^1.0.1",
    "electron-log": "^5.0.0",
    "extract-zip": "^2.0.1",
    "js-tiktoken": "^1.0.21",
    "lucide-react": "^0.562.0",
    "node-addon-api": "^8.5.0",
    "node-mac-permissions": "^2.5.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "vm2": "^3.9.19",
    "zustand": "^4.4.7"
  },
  "build": {
    "appId": "com.intools.app",
    "productName": "InTools",
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "extendInfo": {
        "NSLocationWhenInUseUsageDescription": "InTools 需要访问您的位置以提供位置相关功能（如地图定位、天气查询等）",
        "NSLocationUsageDescription": "InTools 需要访问您的位置以提供位置相关功能",
        "NSCameraUsageDescription": "插件可能需要访问摄像头以提供拍照、视频等功能",
        "NSMicrophoneUsageDescription": "插件可能需要访问麦克风以提供录音、语音识别等功能"
      }
    },
    "asarUnpack": [
      "node_modules/electron-get-location/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/node-mac-permissions/**/*",
      "node_modules/sharp/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
