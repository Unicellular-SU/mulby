{
  "id": "ai-translator",
  "name": "ai-translator",
  "version": "1.0.0",
  "author": "intools",
  "displayName": "AI 翻译",
  "description": "使用系统内置 AI 的翻译插件，支持语言选择与模型配置",
  "main": "dist/main.js",
  "ui": "ui/index.html",
  "icon": "icon.png",
  "window": {
    "width": 960,
    "height": 680,
    "minWidth": 560,
    "minHeight": 420,
    "maxWidth": 1200,
    "maxHeight": 960
  },
  "features": [
    {
      "code": "main",
      "explain": "AI 翻译",
      "cmds": [
        {
          "type": "keyword",
          "value": "ai-translator"
        },
        {
          "type": "keyword",
          "value": "翻译"
        },
        {
          "type": "keyword",
          "value": "translate"
        }
      ]
    },
    {
      "code": "settings",
      "explain": "翻译设置",
      "route": "/settings",
      "cmds": [
        {
          "type": "keyword",
          "value": "翻译设置"
        },
        {
          "type": "keyword",
          "value": "translator-settings"
        }
      ]
    }
  ]
}
